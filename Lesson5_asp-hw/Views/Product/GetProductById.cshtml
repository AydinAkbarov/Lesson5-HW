@model Lesson5_asp_hw.Models.Product
<style>
	.product-detail-wrapper {
		max-width: 600px;
		margin: 50px auto;
		background: #fff;
		padding: 30px 40px;
		border-radius: 16px;
		box-shadow: 0 10px 25px rgba(0,0,0,0.1);
		font-family: 'Segoe UI', sans-serif;
	}
	.product-detail-wrapper h1 {
				font-weight: 700;

		text-align: center;
		margin-bottom: 20px;
		color: #333;
	}
	.product-detail-wrapper p {
		font-size: 18px;
		color: #555;
		margin-bottom: 10px;
	}
	.price{
		font-size: 24px;
		font-weight: 700;
		color: #60B360;
	}
</style>
<div class="product-detail-wrapper">
	<h1>@Model.Name</h1>
	 <p class="price" >Price - @Model.Price $</p>
	 <p>Description - @Model.Description</p>
</div>
