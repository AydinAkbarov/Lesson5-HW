<style>
    .delete-form {
        max-width: 400px;
        margin: 30px auto;
        padding: 25px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        text-align: center;
    }

    .delete-form input {
        width: 70%;
        padding: 10px 12px;
        margin-bottom: 15px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 16px;
    }

    .delete-form button {
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        background: #dc3545;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.3s ease, transform 0.2s ease;
    }

    .delete-form button:hover {
        background: #b02a37;
        transform: translateY(-2px);
    }
</style>

<form asp-controller="Product" asp-action="DeleteProduct" method="post" class="delete-form">
    <input type="number" name="id" placeholder="Enter Product ID" required />
    <br />
    <button type="submit">Delete Product</button>
</form>
