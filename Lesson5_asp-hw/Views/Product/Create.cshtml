@model Lesson5_asp_hw.Models.Product

<style>
    body {
        background: #f5f7fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .form-wrapper {
        max-width: 600px;
        margin: 50px auto;
        background: #fff;
        padding: 30px 40px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .form-wrapper h2 {
        text-align: center;
        margin-bottom: 30px;
        font-weight: 600;
        color: #333;
    }

    .form-label {
        font-weight: 500;
        margin-bottom: 6px;
        display: block;
        color: #555;
    }

    .form-control {
        border-radius: 12px;
        padding: 10px 15px;
        border: 1px solid #ccc;
        width: 100%;
        box-sizing: border-box;
        margin-bottom: 20px;
        transition: border-color .3s ease;
    }

    .form-control:focus {
        border-color: #60B360;
        outline: none;
        box-shadow: 0 0 0 2px rgba(13,110,253,0.2);
    }

    .btn-primary {
        width: 100%;
        padding: 12px 0;
        border-radius: 12px;
        color:#FFFFFF;
        font-size: 16px;
        font-weight: 600;
        background: #60B360;
        border: none;
        transition: background .3s ease, transform .2s ease;
    }

    .btn-primary:hover {
        background: #437D43;
        transform: translateY(-2px);
    }
</style>

<div class="form-wrapper">
    <h2>Create New Product</h2>

    <form asp-controller="@nameof(ProductController.Product)"
          asp-action="@nameof(ProductController.AddProduct)"
          method="post">

        <label asp-for="Name" class="form-label">Product Name</label>
        <input asp-for="Name" class="form-control" placeholder="Enter Product Name" />

        <label asp-for="Price" class="form-label">Product Price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Enter Product Price" />

        <label asp-for="Description" class="form-label">Product Description</label>
        <textarea asp-for="Description" class="form-control" placeholder="Enter Product Description" rows="3"></textarea>

        <button type="submit" class="btn btn-primary">Save Product</button>
    </form>
</div>
