<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProductApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
         html, body {
        height: 100%;
        margin: 0;
    }

    body {
        display: flex;
        flex-direction: column;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6f8;
    }

    main {
        flex: 1;
    }

    header { 
        background: #3e6b3c; 
        padding: 20px; 
        color: #fff; 
        text-align: center; 
        font-size: 24px; 
    }

    nav a { 
        color: #fff; 
        margin: 0 15px; 
        text-decoration: none; 
        font-weight: 600; 
    }

    nav a:hover { 
        text-decoration: underline; 
    }

    footer { 
        text-align: center; 
        padding: 15px; 
        background: #222; 
        color: #fff; 
    }
        body { font-family: 'Segoe UI', sans-serif; background: #f4f6f8; }
        header { background: #3e6b3c; padding: 20px; color: #fff; text-align: center; font-size: 24px; }
        nav a { color: #fff; margin: 0 15px; text-decoration: none; font-weight: 600; }
        nav a:hover { text-decoration: underline; }
        footer { text-align: center; padding: 15px; margin-top: 40px; background: #222; color: #fff; }
    </style>
</head>
<body>
    <header>
        Product Management App
        <nav>
            <a asp-controller="@nameof(ProductController.Product)" asp-action="@nameof(ProductController.Index)">Home</a>
            <a asp-controller="@nameof(ProductController.Product)" asp-action="@nameof(ProductController.Create)">Create Product</a>
            <a asp-controller="@nameof(ProductController.Product)" asp-action="@nameof(ProductController.GetAllProducts)">All Products</a>
            <a asp-controller="@nameof(ProductController.Product)" asp-action="@nameof(ProductController.GetProductByPrice)">Filter By Price</a>
            <a asp-controller="@nameof(ProductController.Product)" asp-action="@nameof(ProductController.DeleteProduct)">Delete Product</a>
            <a asp-controller=""></a>

        </nav>
    </header>
    <main>
    <div class="container mt-4">
        @RenderBody()
    </div>
</main>
    <footer>
        &copy; @DateTime.Now.Year - ProductApp
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
